# ============================================================
#   BeatAnimeVerse Bot — Complete Environment Variables
#   Place this as .env in /app/ on Render or set in Dashboard
# ============================================================


# ────────────────────────────────────────────────────────────
# 🔴 REQUIRED — Bot will NOT start without these
# ────────────────────────────────────────────────────────────

# Your bot token from @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your Telegram user ID (get it from @userinfobot)
ADMIN_ID=829342319
OWNER_ID=829342319

# PostgreSQL database URL (from Neon or any Postgres provider)
# Format: postgresql://user:password@host/dbname
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# MongoDB URI (from MongoDB Atlas — needed for couples, gban, chatbot etc.)
# Format: mongodb+srv://user:password@cluster.mongodb.net/dbname
MONGO_DB_URI=mongodb+srv://user:password@cluster.mongodb.net/beatanime


# ────────────────────────────────────────────────────────────
# 🟡 IMPORTANT — Strongly recommended to set these
# ────────────────────────────────────────────────────────────

# Your bot's display name
BOT_NAME=BeatAnime Bot

# Your public anime channel URL (shown in /start and buttons)
PUBLIC_ANIME_CHANNEL_URL=https://t.me/BeatAnime

# Request / discussion channel URL
REQUEST_CHANNEL_URL=https://t.me/Beat_Hindi_Dubbed

# Admin contact username (no @)
ADMIN_CONTACT_USERNAME=Beat_Anime_Ocean

# Support chat username (no @)
SUPPORT_CHAT=Beat_Anime_Discussion

# Render deployment URL (needed for health check webhook)
# Example: https://beat-management-bot.onrender.com
RENDER_EXTERNAL_URL=https://beat-management-bot.onrender.com

# Port for health check server (Render default is 10000)
PORT=10000


# ────────────────────────────────────────────────────────────
# ⚡ PANEL SPEED — Fastest option: set this
# ────────────────────────────────────────────────────────────

# Comma-separated image URLs for all panels (instant, no API call)
# Bot picks one at random for each panel. Add 3–10 URLs for variety.
# Without this, bot fetches from waifu.im/anilist (adds 1–3s delay)
PANEL_PICS=https://telegra.ph/file/40eb1ed850cdea274693e.jpg,https://telegra.ph/file/your-image-2.jpg

# Admin panel image specifically (overrides PANEL_PICS for admin panel only)
ADMIN_PANEL_IMAGE_URL=

# Stats panel image
STATS_IMAGE_URL=

# Settings panel image
SETTINGS_IMAGE_URL=

# Broadcast panel image
BROADCAST_PANEL_IMAGE_URL=


# ────────────────────────────────────────────────────────────
# 🎭 WELCOME & START PANEL
# ────────────────────────────────────────────────────────────

# Welcome image shown on /start (leave empty to skip)
WELCOME_IMAGE_URL=https://telegra.ph/file/40eb1ed850cdea274693e.jpg

# Help panel image (shown on /help for regular users)
HELP_IMAGE_URL=

# Source channel + message ID to copy as welcome message
# Forward a message to your bot → right-click → Copy Link → use the number after /
# Channel: put the channel ID (like -1001234567890)
WELCOME_SOURCE_CHANNEL=-1002530952988
WELCOME_SOURCE_MESSAGE_ID=32

# Custom welcome text (leave empty to use WELCOME_SOURCE_CHANNEL image above)
BOT_WELCOME_TEXT=

# Custom help text shown to users on /help (leave empty for default)
HELP_TEXT_CUSTOM=

# Custom full bot help text (shown on /help for admin)
BOT_HELP_TEXT=


# ────────────────────────────────────────────────────────────
# 📺 HELP PANEL CHANNEL BUTTONS
# Shown as buttons on /help for regular users
# ────────────────────────────────────────────────────────────

HELP_CHANNEL_1_URL=https://t.me/BeatAnime
HELP_CHANNEL_1_NAME= ᴀɴɪᴍᴇ ᴄʜᴀɴɴᴇʟ

HELP_CHANNEL_2_URL=https://t.me/Beat_Anime_Discussion
HELP_CHANNEL_2_NAME= ᴅɪsᴄᴜssɪᴏɴ

HELP_CHANNEL_3_URL=https://t.me/Beat_Hindi_Dubbed
HELP_CHANNEL_3_NAME= ʀᴇǫᴜᴇsᴛ


# ────────────────────────────────────────────────────────────
# 🔘 BUTTON TEXT — Customise button labels
# ────────────────────────────────────────────────────────────

JOIN_BTN_TEXT=Join Now
HERE_IS_LINK_TEXT=ʜᴇʀᴇ ɪs ʏᴏᴜʀ ʟɪɴᴋ! ᴄʟɪᴄᴋ ʙᴇʟᴏᴡ ᴛᴏ ᴘʀᴏᴄᴇᴇᴅ
LINK_EXPIRED_TEXT=This invite link has expired. Please click the post button again.
ANIME_BTN_TEXT=Anime Channel
REQUEST_BTN_TEXT=Request Anime
CONTACT_BTN_TEXT=Contact Admin
FORCE_SUB_TEXT=Please join our channels first:

# Button style for admin panel labels
# Options: mathbold (𝗕𝗢𝗟𝗗), bold (bold), plain, smallcaps
BUTTON_STYLE=mathbold


# ────────────────────────────────────────────────────────────
# ⏱ LINK SETTINGS
# ────────────────────────────────────────────────────────────

# How many minutes before a generated invite link expires
LINK_EXPIRY_MINUTES=5


# ────────────────────────────────────────────────────────────
# 🎬 POSTER & MEDIA APIs
# ────────────────────────────────────────────────────────────

# TMDB API key — for /movie and /tvshow poster generation
# Get free at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ImgBB API key — for image hosting (optional, used if needed)
# Get free at: https://api.imgbb.com
IMGBB_API_KEY=


# ────────────────────────────────────────────────────────────
# 💬 MODULE API KEYS
# ────────────────────────────────────────────────────────────

# Currency converter — for /cash command
# Get free at: https://app.exchangerate-api.com
CASH_API_KEY=

# World time API — for /time command
# Get free at: https://timezonedb.com/api
TIME_API_KEY=

# Anthropic Claude API — for /chatbot AI responses
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=


# ────────────────────────────────────────────────────────────
# 📢 BROADCAST SETTINGS
# ────────────────────────────────────────────────────────────

# How many users to send per batch
BROADCAST_CHUNK_SIZE=1000

# Minimum users before broadcast is allowed
BROADCAST_MIN_USERS=5000

# Minimum minutes between scheduled broadcasts
BROADCAST_INTERVAL_MIN=20

# Rate limit delay between messages in seconds (0.05 = 20 msg/s)
RATE_LIMIT_DELAY=0.05


# ────────────────────────────────────────────────────────────
# 🔵 LOADING ANIMATION
# ────────────────────────────────────────────────────────────

# Sticker file_id to send as loading animation (optional)
# Leave empty for default ❗❗❗ text animation
# To set: forward a sticker to bot then use /set_loader (reply to it)
TRANSITION_STICKER=

# Start image shown in /alive command
START_IMG=https://telegra.ph/file/40eb1ed850cdea274693e.jpg


# ────────────────────────────────────────────────────────────
# 👑 PRIVILEGE LEVELS (space-separated user IDs)
# ────────────────────────────────────────────────────────────

# Sudo users — same as admin for most commands
DRAGONS=

# Developer users — can use /sh, /eval etc.
DEV_USERS=

# Support users — can gban, handle reports
DEMONS=

# Tiger users — whitelist level
TIGERS=

# Whitelist users — basic privilege
WOLVES=


# ────────────────────────────────────────────────────────────
# ⚙️ FEATURE FLAGS
# ────────────────────────────────────────────────────────────

# Allow ! as command prefix in addition to /
ALLOW_EXCL=True

# Delete command messages after processing
DEL_CMDS=True

# Modules to NOT load (space-separated module names)
# Default skips: tagall telegraph backups country (slow/broken without deps)
NO_LOAD=tagall telegraph backups country
