# ================================================================
#  BeatAniVerse Bot — Environment Variables
# ================================================================

# ── REQUIRED ────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_ID=your_telegram_numeric_id
OWNER_ID=your_telegram_numeric_id   # same as ADMIN_ID usually

# ── DATABASE (at least one required) ───────────────────────────
# NeonDB: https://neon.tech → free PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# MongoDB Atlas: https://cloud.mongodb.com → free cluster
MONGO_DB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/beataniversebot

# ── BRANDING ────────────────────────────────────────────────────
BOT_NAME=BeatAniVerse Bot
PUBLIC_ANIME_CHANNEL_URL=https://t.me/BeatAnime
REQUEST_CHANNEL_URL=https://t.me/Beat_Hindi_Dubbed
ADMIN_CONTACT_USERNAME=Beat_Anime_Ocean

# ── HELP PAGE (what users see on /help) ─────────────────────────
# HTML is supported. Leave empty to use the default.
HELP_TEXT_CUSTOM=<b>🎌 Welcome to BeatAniVerse!</b>\n\nYour gateway to Anime, Manga & Movies!\n\nUse the buttons below to join our channels.
HELP_CHANNEL_1_URL=https://t.me/BeatAnime
HELP_CHANNEL_1_NAME=📢 Anime Channel
HELP_CHANNEL_2_URL=https://t.me/Beat_Anime_Discussion
HELP_CHANNEL_2_NAME=💬 Discussion
HELP_CHANNEL_3_URL=https://t.me/Beat_Hindi_Dubbed
HELP_CHANNEL_3_NAME=🎬 Hindi Dubbed

# ── OPTIONAL API KEYS ───────────────────────────────────────────
TMDB_API_KEY=your_tmdb_key_for_movie_and_tv_posts

# ── LINK PROVIDER ───────────────────────────────────────────────
LINK_EXPIRY_MINUTES=5
# Welcome message: copy from a channel message (optional)
WELCOME_SOURCE_CHANNEL=-1002530952988
WELCOME_SOURCE_MESSAGE_ID=32

# ── IMAGE / STICKER PANELS ──────────────────────────────────────
WELCOME_IMAGE_URL=https://telegra.ph/file/xxxxx.jpg
HELP_IMAGE_URL=
ADMIN_PANEL_IMAGE_URL=
STATS_IMAGE_URL=
TRANSITION_STICKER=CAACAgUAAxkBAAJYs...   # sticker file_id

# ── SERVER ──────────────────────────────────────────────────────
PORT=10000

# ── POSTER DB CHANNEL ───────────────────────────────────────────────────────
# Channel where generated posters are saved for fast reuse.
# Bot must be admin in this channel.
# Get the channel ID (e.g. -1001234567890) from @userinfobot
POSTER_DB_CHANNEL=-1001234567890

# ── BUTTON & LINK TEXT ──────────────────────────────────────────────────────
# All of these can also be changed directly from Admin Panel → Settings → ENV
JOIN_BTN_TEXT=Join Now
HERE_IS_LINK_TEXT=ʜᴇʀᴇ ɪs ʏᴏᴜʀ ʟɪɴᴋ! ᴄʟɪᴄᴋ ʙᴇʟᴏᴡ ᴛᴏ ᴘʀᴏᴄᴇᴇᴅ
ANIME_BTN_TEXT=Anime Channel
REQUEST_BTN_TEXT=Request Anime
CONTACT_BTN_TEXT=Contact Admin
FORCE_SUB_TEXT=Please join our channels to continue:

# ── BUTTON STYLE ─────────────────────────────────────────────────────────────
# Options: mathbold | smallcaps
# Also changeable from Admin Panel → Settings → BTN STYLE
BUTTON_STYLE=mathbold
